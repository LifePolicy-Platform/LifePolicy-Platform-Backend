<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="maventest.mapper.AppUserMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id"
        parameterType="maventest.entity.AppUserEntity">
        INSERT INTO app_user (username, password_hash, display_name, enabled)
        VALUES (#{username}, #{passwordHash}, #{displayName}, #{enabled})
    </insert>

    <select id="existsByUserName" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM app_user
        WHERE username = #{username}
    </select>

    <insert id="insertRole">
        INSERT INTO user_role (user_id, role_name)
        VALUES (#{userId}, #{roleName})
    </insert>

    <resultMap id="AppUserResultMap" type="maventest.entity.AppUserEntity">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="displayName" column="display_name"/>
        <result property="enabled" column="enabled"/>
        <collection property="roles" ofType="String">
            <result column="role_name"/>
        </collection>
    </resultMap>

    <select id="findAllUser" resultMap="AppUserResultMap">
        SELECT u.id,
            u.username,
            u.password_hash,
            u.display_name,
            u.enabled,
            ur.role_name
        FROM app_user u
        LEFT JOIN user_role ur ON u.id = ur.user_id
        ORDER BY u.id
    </select>

    <!-- 修改user資訊-->
    <update id="updateByUserName" parameterType="maventest.entity.AppUserEntity">
        UPDATE app_user
        SET display_name = #{displayName},
            password_hash = #{passwordHash},
            enabled = #{enabled}
        WHERE username = #{username}
    </update>

    <!-- 修改user role 先刪除-->
    <delete id="delectUserRole" parameterType="String">
        DELETE ur FROM user_role ur
        INNER JOIN app_user u ON ur.user_id = u.id
        WHERE u.username = #{username}
    </delete>


    <!-- 再刪使用者(主表) -->
    <delete id="deleteUserByUsername">
        DELETE FROM app_user WHERE username = #{username}
    </delete>

</mapper>