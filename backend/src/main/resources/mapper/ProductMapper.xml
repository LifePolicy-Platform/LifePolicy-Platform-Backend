<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="maventest.policyapplication.infrastructure.repository.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="maventest.policyapplication.domain.entity.ProductEntity">
    <id     property="productCode"  column="PRODUCT_CODE"/>
    <result property="productName"  column="PRODUCT_NAME"/>
    <result property="productType"  column="PRODUCT_TYPE"/>
    <result property="basePremium"  column="BASE_PREMIUM"/>
    <result property="minAmount"    column="MIN_AMOUNT"/>
    <result property="maxAmount"    column="MAX_AMOUNT"/>
    <result property="minAge"       column="MIN_AGE"/>
    <result property="maxAge"       column="MAX_AGE"/>
    <result property="status"       column="STATUS"/>
    <result property="remark"       column="REMARK"/>
    <result property="createTime"   column="CREATE_TIME"/>
    <result property="updateTime"   column="UPDATE_TIME"/>
    <result property="updateUser"   column="UPDATE_USER"/>
    <result property="productTerm"  column="PRODUCT_TERM"/>
</resultMap>

    <select id="findByCode" parameterType="java.lang.String" resultMap="ProductResultMap">
        SELECT PRODUCT_CODE, PRODUCT_NAME, PRODUCT_TYPE, BASE_PREMIUM,
               MIN_AMOUNT, MAX_AMOUNT, MIN_AGE, MAX_AGE,
               STATUS, REMARK, CREATE_TIME,UPDATE_TIME,UPDATE_USER,PRODUCT_TERM
        FROM tb_product
        WHERE PRODUCT_CODE = #{productCode}
    </select>

    <select id="findAll" resultMap="ProductResultMap">
        SELECT PRODUCT_CODE, PRODUCT_NAME, PRODUCT_TYPE, BASE_PREMIUM,
               MIN_AMOUNT, MAX_AMOUNT, MIN_AGE, MAX_AGE,
               STATUS, REMARK, CREATE_TIME,UPDATE_TIME,UPDATE_USER,PRODUCT_TERM
        FROM tb_product
        ORDER BY PRODUCT_CODE
    </select>

</mapper>